# ~/.zshrc (macOS)

# Homebrew PATH
if [ -f /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -f /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# PATH extras
# /usr/local/bin covers ollama (ollama.com) and code (VSCode ARM installer)
export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"

# Auto-start tmux when opening Ghostty — attach existing session or create new
if [ -z "$TMUX" ] && [ -n "$GHOSTTY_RESOURCES_DIR" ]; then
    exec tmux new-session -A -s main
fi

# Editor
export EDITOR=vim
export VISUAL=vim

# Prevent venv from overwriting our custom prompt
export VIRTUAL_ENV_DISABLE_PROMPT=1

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt HIST_IGNORE_ALL_DUPS    # remove any older copy when a duplicate is added
setopt HIST_SAVE_NO_DUPS       # don't write duplicates to the history file on disk
setopt HIST_FIND_NO_DUPS       # skip duplicates when navigating with ↑/↓
setopt HIST_IGNORE_SPACE       # don't record commands prefixed with a space
setopt SHARE_HISTORY           # share history across all open shells in real time
setopt APPEND_HISTORY          # append to history file on exit (don't overwrite)
setopt EXTENDED_HISTORY        # save timestamp + elapsed time with each entry
setopt INTERACTIVE_COMMENTS    # allow # comments in interactive shell

# Completion
autoload -Uz compinit

if type brew &>/dev/null; then
    FPATH="$(brew --prefix)/share/zsh-completions:$(brew --prefix)/share/zsh/site-functions:${FPATH}"
fi

# Rebuild .zcompdump once per day
if [ "$(find ~/.zcompdump -mtime +1 2>/dev/null)" ]; then
    compinit -i
else
    compinit -C -i
fi

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*:descriptions' format '%F{yellow}-- %d --%f'
zstyle ':completion:*:warnings' format '%F{red}No matches for: %d%f'

# zsh-autosuggestions
if [ -f "$(brew --prefix 2>/dev/null)/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
    . "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi

# zsh-syntax-highlighting (must be sourced last)
if [ -f "$(brew --prefix 2>/dev/null)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
    . "$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
fi

# ls colours
export CLICOLOR=1
export LSCOLORS='ExGxFxDxCxDxDxhbhbExEx'

# Catppuccin Mocha colours
_R='%F{#f38ba8}'   # Red    (root alarm)
_G='%F{#a6e3a1}'   # Green  (user)
_Y='%F{#f9e2af}'   # Yellow (host)
_B='%F{#89b4fa}'   # Blue   (path)
_M='%F{#cba6f7}'   # Mauve  (decorators)
_T='%F{#cdd6f4}'   # Text   (local time)
_C='%F{#94e2d5}'   # Teal   (UTC time)
_K='%F{#89dceb}'   # Sky    (kubectl context)
_RST='%f'

# Prompt — two lines:
#   [zsh] user@host:/path  Local 2026-05-27 15:30:00  UTC 2026-05-27 13:30:00  k8s:cluster
#   $ (green ok / red error)   ← command starts here
setopt PROMPT_SUBST

_zsh_prompt() {
    local exit_ok=$?
    local sym sym_col local_time utc_time kctx kctx_col venv_info

    local_time=$(date '+%Y-%m-%d %H:%M:%S')
    utc_time=$(date -u '+%Y-%m-%d %H:%M:%S')

    # venv indicator — shown at very start of the prompt line
    venv_info=""
    if [ -n "$VIRTUAL_ENV" ]; then
        local venv_name="${VIRTUAL_ENV_PROMPT:-$(basename "$VIRTUAL_ENV")}"
        venv_info="${_M}(${venv_name})${_RST} "
    fi

    # kubectl current context — shows live cluster or "disconnected"
    if command -v kubectl &>/dev/null; then
        kctx=$(kubectl config current-context 2>/dev/null)
        if [ -n "$kctx" ]; then
            kctx_col="${_K}"
        else
            kctx="disconnected"
            kctx_col="${_R}"
        fi
    else
        kctx="disconnected"
        kctx_col="${_R}"
    fi

    if [ $exit_ok -eq 0 ]; then
        sym_col='%F{#a6e3a1}'
    else
        sym_col='%F{#f38ba8}'
    fi

    if [ "$(id -u)" -eq 0 ]; then
        sym='#'
        PROMPT="${venv_info}${_R}[zsh] %n${_M}@${_Y}%m${_M}:${_B}${PWD}${_RST}  ${_T}Local ${local_time}${_RST}  ${_C}UTC ${utc_time}${_RST}  ${kctx_col}k8s:${kctx}${_RST}
${sym_col}${sym}${_RST} "
    else
        sym='$'
        PROMPT="${venv_info}${_G}[zsh] %n${_M}@${_Y}%m${_M}:${_B}${PWD}${_RST}  ${_T}Local ${local_time}${_RST}  ${_C}UTC ${utc_time}${_RST}  ${kctx_col}k8s:${kctx}${_RST}
${sym_col}${sym}${_RST} "
    fi
}

precmd_functions+=(_zsh_prompt)

# Key bindings
bindkey -e
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# Aliases
if [ -f ~/.zsh_aliases ]; then
    . ~/.zsh_aliases
fi

# tmux shortcut
alias t='tmux'

# CLI tool completions — add tools here that support "tool completion zsh"
_zsh_load_completions() {
    local tool output
    for tool in kubectl helm flux kind k3d docker ollama; do
        if command -v "$tool" &>/dev/null; then
            output=$("$tool" completion zsh 2>/dev/null)
            [ -n "$output" ] && eval "$output"
        fi
    done
    # extend completion to the k alias for kubectl
    command -v kubectl &>/dev/null && compdef k=kubectl
}
_zsh_load_completions
unset -f _zsh_load_completions
